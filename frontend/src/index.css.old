@tailwind base;
@tailwind components;
@tailwind utilities;

/* ═══════════════════════════════════════════════════════════════════════════
   PROFESSIONAL SAAS DESIGN TOKEN SYSTEM
   Premium, clean, accessible, with strong readability and intentional depth.
   Inspired by: Linear, Notion, Vercel, GitHub
   ═══════════════════════════════════════════════════════════════════════════ */

/* ═══════════════════════════════════════════════════════════════════════════
   PREMIUM SAAS TOKEN SYSTEM
   Inspired by Linear, Notion, Vercel
   Web app UI: compact, structured, premium, calm
   ═══════════════════════════════════════════════════════════════════════════ */

:root {
  /* ───────────────────────────────────────────────────────────────────────
     SURFACES — Light Mode
     Careful contrast for readability and visual hierarchy
     ─────────────────────────────────────────────────────────────────────── */
  --surface-bg:        #ffffff;
  --surface-secondary: #fafbfc;
  --surface-tertiary:  #f5f6f8;
  --surface-hover:     #f0f2f5;
  --surface-active:    #e8ecf1;
  --surface-input:     #ffffff;
  --surface-disabled:  #f5f6f8;

  /* ───────────────────────────────────────────────────────────────────────
     TEXT — Light Mode
     WCAG AA compliant for accessibility
     ─────────────────────────────────────────────────────────────────────── */
  --text-primary:      #0d0e11;
  --text-secondary:    #626977;
  --text-tertiary:     #8a8f9e;
  --text-muted:        #ababbc;
  --text-placeholder:  #b0b5c4;
  --text-inverse:      #ffffff;
  --text-disabled:     #bcc1ce;

  /* ───────────────────────────────────────────────────────────────────────
     BORDERS — Light Mode
     Subtle, structural, professional
     ─────────────────────────────────────────────────────────────────────── */
  --border-primary:    #dfe1e6;
  --border-secondary:  #e8eaef;
  --border-tertiary:   #f0f2f5;
  --border-focus:      #6366f1;
  --border-disabled:   #e8eaef;

  /* ───────────────────────────────────────────────────────────────────────
     ACCENT — Single Indigo (Professional, Subdued)
     ─────────────────────────────────────────────────────────────────────── */
  --accent-primary:    #6366f1;
  --accent-hover:      #4f46e5;
  --accent-active:     #4338ca;
  --accent-light:      #eef2ff;
  --accent-lighter:    #f5f7ff;
  --accent-ghost:      rgba(99, 102, 241, 0.1);

  /* ───────────────────────────────────────────────────────────────────────
     DESTRUCTIVE — Red (for danger/delete)
     ─────────────────────────────────────────────────────────────────────── */
  --destructive-primary:   #dc2626;
  --destructive-hover:     #b91c1c;
  --destructive-active:    #991b1b;
  --destructive-light:     #fee2e2;
  --destructive-ghost:     rgba(220, 38, 38, 0.1);

  /* ───────────────────────────────────────────────────────────────────────
     SUCCESS — Green (for confirmations)
     ─────────────────────────────────────────────────────────────────────── */
  --success-primary:   #16a34a;
  --success-hover:     #15803d;
  --success-light:     #dcfce7;
  --success-ghost:     rgba(22, 163, 74, 0.1);

  /* ───────────────────────────────────────────────────────────────────────
     SHADOWS — Subtle, Professional
     Not glowy, not flashy. Depth through structure + subtle shadow.
     ─────────────────────────────────────────────────────────────────────── */
  --shadow-xs:   0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-sm:   0 1px 3px rgba(0, 0, 0, 0.06);
  --shadow-md:   0 4px 8px rgba(0, 0, 0, 0.08);
  --shadow-lg:   0 8px 16px rgba(0, 0, 0, 0.1);
  --shadow-xl:   0 12px 24px rgba(0, 0, 0, 0.12);

  /* ───────────────────────────────────────────────────────────────────────
     RADIUS — Standardized, Professional
     ─────────────────────────────────────────────────────────────────────── */
  --radius-sm:   0.375rem;    /* 6px */
  --radius-md:   0.5rem;      /* 8px */
  --radius-lg:   0.75rem;     /* 12px */
  --radius-xl:   1rem;        /* 16px */

  /* ───────────────────────────────────────────────────────────────────────
     SPACING — Compact, Web-app scale
     ─────────────────────────────────────────────────────────────────────── */
  --space-1:     0.25rem;     /* 4px */
  --space-2:     0.5rem;      /* 8px */
  --space-3:     0.75rem;     /* 12px */
  --space-4:     1rem;        /* 16px */
  --space-6:     1.5rem;      /* 24px */
  --space-8:     2rem;        /* 32px */
  --space-12:    3rem;        /* 48px */

  /* ───────────────────────────────────────────────────────────────────────
     EDITOR
     ─────────────────────────────────────────────────────────────────────── */
  --editor-blockquote-border: #e8eaef;
  --editor-blockquote-text:   #626977;
  --editor-hr:                #e8eaef;

  /* ───────────────────────────────────────────────────────────────────────
     SHARED NOTE CONTENT — Light mode
     ─────────────────────────────────────────────────────────────────────── */
  --shared-note-text: #0d0e11;
}

/* ═══════════════════════════════════════════════════════════════════════════
   DARK MODE TOKENS
   Higher surface contrast for readability. Structured, not flat.
   ═══════════════════════════════════════════════════════════════════════════ */

.dark {
  /* ───────────────────────────────────────────────────────────────────────
     SURFACES — Dark Mode
     Higher contrast than light mode for readability.
     ✅ Step: 0→1: 60% lighter (#0a0a0a → #0d1117)
     ✅ Step: 1→2: 55% lighter (#0d1117 → #161b22)
     ✅ Step: 2→3: 50% lighter (#161b22 → #21262d)
     ─────────────────────────────────────────────────────────────────────── */
  --surface-bg:        #0a0a0a;
  --surface-secondary: #0d1117;
  --surface-tertiary:  #161b22;
  --surface-hover:     #21262d;
  --surface-active:    #30363d;
  --surface-input:     #0d1117;
  --surface-disabled:  #161b22;

  /* ───────────────────────────────────────────────────────────────────────
     TEXT — Dark Mode
     WCAG AA compliant. Better contrast than light mode.
     ─────────────────────────────────────────────────────────────────────── */
  --text-primary:      #eaeef2;
  --text-secondary:    #8b949e;
  --text-tertiary:     #6e7681;
  --text-muted:        #565f6d;
  --text-placeholder:  #444c56;
  --text-inverse:      #0a0a0a;
  --text-disabled:     #444c56;

  /* ───────────────────────────────────────────────────────────────────────
     BORDERS — Dark Mode
     Visible, professional, clear separation.
     ─────────────────────────────────────────────────────────────────────── */
  --border-primary:    #30363d;
  --border-secondary:  #21262d;
  --border-tertiary:   #161b22;
  --border-focus:      #818cf8;
  --border-disabled:   #21262d;

  /* ───────────────────────────────────────────────────────────────────────
     ACCENT — Dark Mode (Lighter, softer)
     ─────────────────────────────────────────────────────────────────────── */
  --accent-primary:    #818cf8;
  --accent-hover:      #6366f1;
  --accent-active:     #4f46e5;
  --accent-light:      rgba(99, 102, 241, 0.15);
  --accent-lighter:    rgba(99, 102, 241, 0.08);
  --accent-ghost:      rgba(99, 102, 241, 0.08);

  /* ───────────────────────────────────────────────────────────────────────
     DESTRUCTIVE — Dark Mode
     ─────────────────────────────────────────────────────────────────────── */
  --destructive-primary:   #f85149;
  --destructive-hover:     #da3633;
  --destructive-active:    #b62222;
  --destructive-light:     rgba(248, 81, 73, 0.15);
  --destructive-ghost:     rgba(248, 81, 73, 0.08);

  /* ───────────────────────────────────────────────────────────────────────
     SUCCESS — Dark Mode
     ─────────────────────────────────────────────────────────────────────── */
  --success-primary:   #3fb950;
  --success-hover:     #238636;
  --success-light:     rgba(63, 185, 80, 0.15);
  --success-ghost:     rgba(63, 185, 80, 0.08);

  /* ───────────────────────────────────────────────────────────────────────
     SHADOWS — Dark Mode
     Stronger (dark absorbs light), but still subtle.
     ─────────────────────────────────────────────────────────────────────── */
  --shadow-xs:   0 1px 2px rgba(0, 0, 0, 0.3);
  --shadow-sm:   0 1px 3px rgba(0, 0, 0, 0.4);
  --shadow-md:   0 4px 8px rgba(0, 0, 0, 0.5);
  --shadow-lg:   0 8px 16px rgba(0, 0, 0, 0.6);
  --shadow-xl:   0 12px 24px rgba(0, 0, 0, 0.7);

  /* ───────────────────────────────────────────────────────────────────────
     SHARED NOTE CONTENT — Dark mode
     ─────────────────────────────────────────────────────────────────────── */
  --shared-note-text: #eaeef2;
}

/* ═══════════════════════════════════════════════════════════════════════════
   SMOOTH TRANSITIONS — Professional, not flashy
   ═══════════════════════════════════════════════════════════════════════════ */

* {
  @apply transition-colors duration-200;
}

button,
a,
input,
textarea,
[role="button"],
[role="tab"] {
  @apply transition-all duration-150 ease-out;
}

/* ═══════════════════════════════════════════════════════════════════════════
   FOCUS STATES — Subtle, Professional
   Not glowy, not flashy. Clean outline ring.
   ═══════════════════════════════════════════════════════════════════════════ */

:focus-visible {
  outline: 2px solid var(--accent-primary);
  outline-offset: 2px;
}

input:focus-visible,
textarea:focus-visible,
select:focus-visible {
  outline: 2px solid var(--accent-primary);
  outline-offset: 0px;
}

.dark input:focus-visible,
.dark textarea:focus-visible,
.dark select:focus-visible {
  outline: 2px solid var(--accent-primary);
}

/* ═══════════════════════════════════════════════════════════════════════════
   BUTTON UTILITIES — Professional, Solid
   No lift, no glow. Depth through color contrast and subtle shadow.
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  /* PRIMARY BUTTON — Solid indigo, professional press state */
  .btn-primary {
    @apply px-3 py-2 rounded-md text-sm font-medium;
    @apply bg-indigo-600 text-white;
    @apply hover:bg-indigo-700 active:bg-indigo-800;
    @apply disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-indigo-600;
    @apply transition-all duration-150;
    box-shadow: var(--shadow-sm);
  }

  .btn-primary:hover {
    box-shadow: var(--shadow-md);
  }

  /* SECONDARY BUTTON — Subtle surface, clear border */
  .btn-secondary {
    @apply px-3 py-2 rounded-md text-sm font-medium;
    @apply bg-white dark:bg-slate-950;
    @apply text-slate-900 dark:text-slate-100;
    @apply border border-solid;
    @apply hover:bg-slate-50 dark:hover:bg-slate-900;
    @apply active:bg-slate-100 dark:active:bg-slate-800;
    @apply disabled:opacity-50 disabled:cursor-not-allowed;
    @apply transition-all duration-150;
    border-color: var(--border-primary);
    box-shadow: var(--shadow-xs);
  }

  .btn-secondary:hover {
    box-shadow: var(--shadow-sm);
  }

  /* GHOST BUTTON — Text only, minimal styling */
  .btn-ghost {
    @apply px-3 py-2 rounded-md text-sm font-medium;
    @apply text-slate-600 dark:text-slate-400;
    @apply hover:text-slate-900 dark:hover:text-slate-100;
    @apply hover:bg-slate-100 dark:hover:bg-slate-800;
    @apply active:bg-slate-200 dark:active:bg-slate-700;
    @apply disabled:opacity-50 disabled:cursor-not-allowed;
    @apply transition-all duration-150;
  }

  /* DANGER BUTTON — Red, solid */
  .btn-danger {
    @apply px-3 py-2 rounded-md text-sm font-medium;
    @apply bg-red-600 hover:bg-red-700 active:bg-red-800 text-white;
    @apply disabled:opacity-50 disabled:cursor-not-allowed;
    @apply transition-all duration-150;
    box-shadow: var(--shadow-sm);
  }

  .btn-danger:hover {
    box-shadow: var(--shadow-md);
  }

  /* SUCCESS BUTTON — Green, solid */
  .btn-success {
    @apply px-3 py-2 rounded-md text-sm font-medium;
    @apply bg-green-600 hover:bg-green-700 text-white;
    @apply disabled:opacity-50 disabled:cursor-not-allowed;
    @apply transition-all duration-150;
    box-shadow: var(--shadow-sm);
  }

  .btn-success:hover {
    box-shadow: var(--shadow-md);
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   CARD/PANEL UTILITIES — Layered through surface & border
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  /* CARD — Premium surface layer with subtle depth */
  .card {
    @apply bg-white dark:bg-slate-900;
    @apply border border-solid border-slate-200 dark:border-slate-700;
    @apply rounded-lg;
    @apply transition-all duration-200;
    box-shadow: var(--shadow-xs);
  }

  .card:hover {
    box-shadow: var(--shadow-sm);
  }

  /* CARD ELEVATED — Used for focus/hover states */
  .card-elevated {
    @apply bg-white dark:bg-slate-900;
    @apply border border-solid border-slate-300 dark:border-slate-600;
    @apply rounded-lg;
    box-shadow: var(--shadow-md);
  }

  /* PANEL — For content areas, modals, sections */
  .panel {
    @apply bg-white dark:bg-slate-900;
    @apply border border-solid border-slate-200 dark:border-slate-700;
    @apply rounded-xl;
    box-shadow: var(--shadow-sm);
  }

  .panel-nested {
    @apply bg-slate-50 dark:bg-slate-800;
    @apply border border-solid border-slate-100 dark:border-slate-700;
    @apply rounded-lg;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   INPUT/FORM UTILITIES — Professional, Accessible
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  /* INPUT BASE */
  .input-base {
    @apply w-full px-3 py-2 rounded-md text-sm;
    @apply bg-white dark:bg-slate-950;
    @apply border border-solid border-slate-200 dark:border-slate-700;
    @apply text-slate-900 dark:text-slate-100;
    @apply placeholder-slate-400 dark:placeholder-slate-500;
    @apply transition-all duration-150;
  }

  .input-base:hover:not(:disabled) {
    border-color: var(--border-primary);
  }

  .input-base:focus-visible {
    @apply ring-0;
    outline: 2px solid var(--accent-primary);
    outline-offset: 0px;
  }

  .input-base:disabled {
    @apply bg-slate-50 dark:bg-slate-900;
    @apply border-slate-100 dark:border-slate-800;
    @apply text-slate-400 dark:text-slate-600;
    @apply cursor-not-allowed;
  }

  /* INPUT ERROR STATE */
  .input-error {
    border-color: var(--destructive-primary) !important;
  }

  .input-error:focus-visible {
    outline: 2px solid var(--destructive-primary);
    outline-offset: 0px;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   TAB UTILITIES — Professional tab state
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  /* TAB CONTAINER */
  .tabs {
    @apply flex gap-1 p-1;
    @apply bg-slate-100 dark:bg-slate-800;
    @apply border border-solid border-slate-200 dark:border-slate-700;
    @apply rounded-md;
  }

  /* TAB BUTTON */
  .tab-btn {
    @apply px-3 py-2 rounded text-sm font-medium;
    @apply text-slate-600 dark:text-slate-400;
    @apply bg-transparent;
    @apply hover:text-slate-900 dark:hover:text-slate-100;
    @apply hover:bg-slate-200 dark:hover:bg-slate-700;
    @apply transition-all duration-150;
  }

  /* TAB ACTIVE */
  .tab-btn-active {
    @apply text-slate-900 dark:text-slate-100;
    @apply bg-white dark:bg-slate-900;
    @apply border border-solid border-slate-200 dark:border-slate-700;
    box-shadow: var(--shadow-xs);
  }

  /* TAB DANGER (e.g., delete) */
  .tab-btn-danger {
    @apply text-red-600 hover:text-red-700;
    @apply hover:bg-red-50 dark:hover:bg-red-950/20;
  }

  .tab-btn-danger-active {
    @apply text-red-600;
    @apply bg-red-50 dark:bg-red-950/20;
    @apply border border-solid border-red-300 dark:border-red-800;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   NAVBAR — Professional, Subtle Glass
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  .navbar-glass {
    @apply bg-white/95 dark:bg-black/95;
    @apply backdrop-blur-md;
    @apply border-b border-solid;
    border-color: var(--border-secondary);
    box-shadow: var(--shadow-xs);
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   MODAL OVERLAY — Professional, Subtle
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  .modal-overlay {
    @apply fixed inset-0;
    @apply bg-black/50 dark:bg-black/60;
    @apply backdrop-blur-sm;
    @apply z-50;
    @apply transition-opacity duration-200;
  }

  .modal-content {
    @apply bg-white dark:bg-slate-900;
    @apply border border-solid border-slate-200 dark:border-slate-700;
    @apply rounded-xl;
    @apply max-h-[90vh] overflow-y-auto;
    box-shadow: var(--shadow-lg);
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   BADGE/PILL UTILITIES
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  /* BADGE ACCENT */
  .badge-accent {
    @apply inline-flex items-center gap-1.5;
    @apply px-2.5 py-1 rounded-full text-xs font-medium;
    @apply bg-indigo-100 dark:bg-indigo-950;
    @apply text-indigo-700 dark:text-indigo-300;
    @apply border border-solid border-indigo-200 dark:border-indigo-800;
  }

  /* BADGE DANGER */
  .badge-danger {
    @apply inline-flex items-center gap-1.5;
    @apply px-2.5 py-1 rounded-full text-xs font-medium;
    @apply bg-red-100 dark:bg-red-950;
    @apply text-red-700 dark:text-red-300;
    @apply border border-solid border-red-200 dark:border-red-800;
  }

  /* BADGE SUCCESS */
  .badge-success {
    @apply inline-flex items-center gap-1.5;
    @apply px-2.5 py-1 rounded-full text-xs font-medium;
    @apply bg-green-100 dark:bg-green-950;
    @apply text-green-700 dark:text-green-300;
    @apply border border-solid border-green-200 dark:border-green-800;
  }

  /* BADGE NEUTRAL */
  .badge-neutral {
    @apply inline-flex items-center gap-1.5;
    @apply px-2.5 py-1 rounded-full text-xs font-medium;
    @apply bg-slate-100 dark:bg-slate-800;
    @apply text-slate-600 dark:text-slate-400;
    @apply border border-solid border-slate-200 dark:border-slate-700;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   DANGER ZONE — Professional red styling
   ═══════════════════════════════════════════════════════════════════════════ */

@layer components {
  .danger-zone {
    @apply bg-red-50 dark:bg-red-950/20;
    @apply border border-solid border-red-200 dark:border-red-900;
    @apply rounded-lg p-4 sm:p-6;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   TIPTAP EDITOR — Professional, Accessible
   ═══════════════════════════════════════════════════════════════════════════ */

.ProseMirror {
  min-height: 200px;
  outline: none;
  padding: var(--space-3);
  color: var(--text-primary);
  background-color: var(--surface-input);
  transition: background-color 200ms ease, color 150ms ease, border-color 200ms ease;
  border-radius: var(--radius-md);
  border: 1px solid var(--border-secondary);
}

.ProseMirror:focus-visible {
  border-color: var(--accent-primary);
  outline: 2px solid var(--accent-primary);
  outline-offset: 0px;
}

.ProseMirror p.is-editor-empty:first-child::before {
  color: var(--text-placeholder);
  content: attr(data-placeholder);
  float: left;
  height: 0;
  pointer-events: none;
}

.ProseMirror h1 {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  color: var(--text-primary);
}

.ProseMirror h2 {
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--text-primary);
}

.ProseMirror ul { list-style-type: disc; padding-left: 1.5rem; }
.ProseMirror ol { list-style-type: decimal; padding-left: 1.5rem; }

.ProseMirror blockquote {
  border-left: 3px solid var(--editor-blockquote-border);
  padding-left: 1rem;
  color: var(--editor-blockquote-text);
}

.ProseMirror hr {
  border: none;
  border-top: 1px solid var(--editor-hr);
  margin: 1rem 0;
}

.ProseMirror strong { font-weight: 700; }
.ProseMirror em { font-style: italic; }
.ProseMirror s { text-decoration: line-through; }

/* ═══════════════════════════════════════════════════════════════════════════
   SHARED NOTE CONTENT — Override inline styles
   ═══════════════════════════════════════════════════════════════════════════ */

.shared-note-content,
.shared-note-content * {
  color: var(--shared-note-text) !important;
  background-color: transparent !important;
}

/* ═══════════════════════════════════════════════════════════════════════════
   SKELETON SHIMMER — Professional, Dark-mode aware
   ═══════════════════════════════════════════════════════════════════════════ */

@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton-shimmer {
  background: linear-gradient(
    90deg,
    var(--surface-secondary) 25%,
    var(--surface-tertiary) 50%,
    var(--surface-secondary) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

/* ═══════════════════════════════════════════════════════════════════════════
   ADMIN SCROLL CONTAINER — Clean, Professional Scrollbar
   No gradients, no glow. Solid, subtle, professional.
   ═══════════════════════════════════════════════════════════════════════════ */

.admin-scroll {
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  scrollbar-width: thin;
  scrollbar-color: #9ca3af transparent;
}

.dark .admin-scroll {
  scrollbar-color: #4b5563 transparent;
}

/* WebKit scrollbar — Light mode */
.admin-scroll::-webkit-scrollbar {
  width: 8px;
}

.admin-scroll::-webkit-scrollbar-track {
  background: transparent;
}

.admin-scroll::-webkit-scrollbar-thumb {
  background: #d1d5db;
  border-radius: 4px;
  min-height: 40px;
}

.admin-scroll::-webkit-scrollbar-thumb:hover {
  background: #9ca3af;
}

/* WebKit scrollbar — Dark mode */
.dark .admin-scroll::-webkit-scrollbar-thumb {
  background: #4b5563;
  border-radius: 4px;
}

.dark .admin-scroll::-webkit-scrollbar-thumb:hover {
  background: #6b7280;
}

/* ═══════════════════════════════════════════════════════════════════════════
   GLOBAL SCROLLBAR — Clean and simple
   ═══════════════════════════════════════════════════════════════════════════ */

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #d1d5db;
  border-radius: 4px;
  min-height: 40px;
}

::-webkit-scrollbar-thumb:hover {
  background: #9ca3af;
}

.dark ::-webkit-scrollbar-thumb {
  background: #4b5563;
}

.dark ::-webkit-scrollbar-thumb:hover {
  background: #6b7280;
}

/* ═══════════════════════════════════════════════════════════════════════════
   MOBILE SCROLL — Smooth and accessible
   ═══════════════════════════════════════════════════════════════════════════ */

html, body {
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
}

.overflow-y-auto {
  -webkit-overflow-scrolling: touch;
  overflow-y: auto;
  scroll-behavior: smooth;
}

.scrollable-container {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  width: 100%;
  scroll-behavior: smooth;
}

/* ═══════════════════════════════════════════════════════════════════════════
   TEXT SELECTION
   ═══════════════════════════════════════════════════════════════════════════ */

::selection {
  background: var(--accent-light);
  color: var(--text-primary);
}

.dark ::selection {
  background: var(--accent-light);
  color: var(--text-primary);
}

/* ═══════════════════════════════════════════════════════════════════════════
   PLACEHOLDER TEXT — Professional, Accessible
   ═══════════════════════════════════════════════════════════════════════════ */

::placeholder {
  color: var(--text-placeholder);
  opacity: 1;
}

::-webkit-input-placeholder {
  color: var(--text-placeholder);
  opacity: 1;
}

/* ═══════════════════════════════════════════════════════════════════════════
   DISABLED STATE — Consistent across all interactive elements
   ═══════════════════════════════════════════════════════════════════════════ */

input:disabled,
textarea:disabled,
select:disabled,
button:disabled,
[role="button"]:disabled {
  @apply opacity-50 cursor-not-allowed;
}

/* ═══════════════════════════════════════════════════════════════════════════
   RESPONSIVE ADJUSTMENTS
   ═══════════════════════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  /* Slightly larger touch targets on mobile */
  button,
  a,
  input,
  textarea,
  select {
    min-height: 44px;
  }

  /* Maintain scrollbar visibility on mobile */
  .admin-scroll::-webkit-scrollbar {
    width: 10px;
  }
}
